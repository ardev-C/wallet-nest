VITE_API_BASE_URL=http://localhost:5000/api
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Recommended: URL of your backend finance chat proxy (key stays on server).
VITE_FINANCE_CHAT_PROXY_URL=http://localhost:8787/api/finance-chat
# Production example:
# VITE_FINANCE_CHAT_PROXY_URL=https://api.yourdomain.com/api/finance-chat

# Backward-compatible alias used by older frontend code.
# VITE_MENTOR_PROXY_URL=http://localhost:8787/api/finance-chat

# Server-side Express proxy config (`npm run finance-chat-proxy`)
PORT=8787
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
CORS_ORIGIN=http://localhost:5173,http://localhost:5176,http://localhost:5177
# Production example:
# CORS_ORIGIN=https://app.yourdomain.com

# Dev-only: call Gemini from the browser (exposes the key — do not use in production).
# VITE_GEMINI_API_KEY=
# VITE_GEMINI_MODEL=gemini-2.0-flash

